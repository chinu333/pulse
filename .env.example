# ============================================================
# PULSE - Newsroom AI Orchestrator
# Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values

# --- Azure Authentication (RBAC via azure-identity) ---
# Uses DefaultAzureCredential — automatically chains through:
#   Managed Identity → Azure CLI → VS Code → Azure PowerShell
# No API keys or secrets needed. Just assign the correct RBAC roles:
#   - Azure OpenAI: "Cognitive Services OpenAI User"
#   - Azure AI Search: "Search Index Data Reader"

# --- Azure OpenAI Configuration ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_MODEL_NAME=gpt-4o

# --- Azure OpenAI Embedding Model ---
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# --- Azure AI Search Configuration ---
# Required Roles: "Search Index Data Reader" on the Search resource
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_INDEX_NAME=pulse-knowledge-base

# --- Azure AI Speech Configuration ---
# Required Roles: "Cognitive Services Speech User" on the Speech resource
AZURE_SPEECH_ENDPOINT=https://your-speech-resource.cognitiveservices.azure.com
AZURE_SPEECH_REGION=eastus
SPEECH_REGION=eastus2
SPEECH_RESOURCE_URL=/subscriptions/{sub}/resourceGroups/{rg}/providers/Microsoft.CognitiveServices/accounts/{name}

# --- Azure Video Indexer Configuration ---
AZURE_VIDEO_INDEXER_ACCOUNT_ID=your-video-indexer-account-id
AZURE_VIDEO_INDEXER_LOCATION=eastus
AZURE_VIDEO_INDEXER_RESOURCE_ID=/subscriptions/{sub}/resourceGroups/{rg}/providers/Microsoft.VideoIndexer/accounts/{name}

# --- LangSmith Configuration ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=pulse-newsroom-orchestrator
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Application Settings ---
APP_NAME=PULSE
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# --- Agent Settings ---
AGENT_MAX_ITERATIONS=10
AGENT_TEMPERATURE=0.3
AGENT_MAX_TOKENS=4096

# --- Azure AI Avatar Configuration ---
STT_LOCALES=en-US
TTS_VOICE=en-US-AvaMultilingualNeural
CUSTOM_VOICE_ENDPOINT_ID=
PERSONAL_VOICE_SPEAKER_PROFILE_ID=
CONTINUOUS_CONVERSATION=true
AVATAR_CHARACTER=meg
AVATAR_STYLE=formal
CUSTOM_AVATAR=false
AUTO_RECONNECT=false
USE_LOCAL_VIDEO_FOR_IDLE=false
TRANSPARENT_BACKGROUND=true
ENABLE_OYD=false

# --- Demo Mode (uses mock data when true) ---
DEMO_MODE=true
